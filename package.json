{
  "name": "showbiz",
  "version": "0.1.0",
  "description": "AI-powered video storyboard desktop application",
  "author": "Alex Wanyoike <alex.m.wanyoike@gmail.com>",
  "private": true,
  "type": "module",
  "main": "dist-electron/main.cjs",
  "scripts": {
    "dev": "tauri dev",
    "build": "tauri build",
    "dev:frontend": "vite dev",
    "dev:electron": "node scripts/dev-electron.mjs",
    "build:frontend": "vite build",
    "build:electron": "esbuild electron/main.ts electron/preload.ts --bundle --platform=node --format=cjs --external:electron --outdir=dist-electron --out-extension:.js=.cjs",
    "package:electron": "yarn build:frontend && yarn build:electron && electron-builder",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "build": {
    "appId": "com.showbiz.app",
    "productName": "Showbiz",
    "directories": {
      "output": "dist-package"
    },
    "files": [
      "dist/**",
      "dist-electron/**",
      "src-tauri/src/migrations/*.sql",
      "!node_modules/**"
    ],
    "linux": {
      "target": ["AppImage", "deb"],
      "category": "AudioVideo",
      "icon": "src-tauri/icons/128x128@2x.png",
      "extraResources": [
        { "from": "node_modules/ffmpeg-static/ffmpeg", "to": "bin/ffmpeg" },
        { "from": "node_modules/ffprobe-static/bin/linux/${arch}/ffprobe", "to": "bin/ffprobe" }
      ]
    },
    "mac": {
      "target": ["dmg"],
      "icon": "src-tauri/icons/icon.icns",
      "extraResources": [
        { "from": "node_modules/ffmpeg-static/ffmpeg", "to": "bin/ffmpeg" },
        { "from": "node_modules/ffprobe-static/bin/darwin/${arch}/ffprobe", "to": "bin/ffprobe" }
      ]
    },
    "win": {
      "target": ["nsis"],
      "icon": "src-tauri/icons/icon.ico",
      "extraResources": [
        { "from": "node_modules/ffmpeg-static/ffmpeg.exe", "to": "bin/ffmpeg.exe" },
        { "from": "node_modules/ffprobe-static/bin/win32/${arch}/ffprobe.exe", "to": "bin/ffprobe.exe" }
      ]
    }
  },
  "dependencies": {
    "@ffmpeg/ffmpeg": "^0.12.15",
    "@ffmpeg/util": "^0.12.2",
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slider": "^1.3.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-dialog": "^2.6.0",
    "@tauri-apps/plugin-http": "^2.5.7",
    "@tauri-apps/plugin-shell": "^2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "1.0.4",
    "ffmpeg-static": "^5.3.0",
    "ffprobe-static": "^3.1.0",
    "lucide-react": "^0.555.0",
    "next-themes": "^0.4.6",
    "radix-ui": "^1.4.3",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-router": "^7",
    "tailwind-merge": "^3.4.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@tauri-apps/cli": "^2",
    "@types/node": "^22",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^4",
    "autoprefixer": "^10",
    "electron": "^43.0.0",
    "electron-builder": "^26.15.3",
    "esbuild": "^0.28.1",
    "postcss": "^8",
    "tailwindcss": "^4",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5",
    "vite": "^6",
    "vitest": "^3"
  }
}
