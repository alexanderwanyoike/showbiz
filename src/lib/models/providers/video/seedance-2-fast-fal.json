{
  "id": "seedance-2-fast-fal",
  "name": "Seedance 2.0 Fast",
  "description": "ByteDance Seedance 2.0 Fast via fal.ai: same start/end-frame model, lower cost (720p max, faster tier)",
  "transport": "fal-video",
  "transportOptions": {
    "textToVideoEndpoint": "bytedance/seedance-2.0/fast/text-to-video",
    "imageToVideoEndpoint": "bytedance/seedance-2.0/fast/image-to-video"
  },
  "enabled": true,
  "apiKeyProvider": "fal",
  "provider": "fal.ai",
  "modelFamily": "seedance-2",
  "models": {
    "textToVideo": "seedance-2-fast-fal-t2v",
    "imageToVideo": "seedance-2-fast-fal-i2v"
  },
  "generationModes": {
    "textToVideo": {
      "endpoint": "bytedance/seedance-2.0/fast/text-to-video"
    },
    "imageToVideo": {
      "endpoint": "bytedance/seedance-2.0/fast/image-to-video",
      "inputs": {
        "startImage": true,
        "endImage": true
      }
    }
  },
  "paramMapping": {
    "duration": "duration",
    "resolution": "resolution",
    "aspectRatio": "aspect_ratio",
    "audio": "generate_audio",
    "imageInput": "image_url"
  },
  "fixedParams": {},
  "capabilities": {
    "durations": ["auto", "4", "5", "6", "7", "8", "9", "10", "11", "12"],
    "resolutions": ["480p", "720p"],
    "aspectRatios": ["auto", "21:9", "16:9", "4:3", "1:1", "3:4", "9:16"],
    "hasAudio": true
  },
  "defaults": {
    "duration": "auto",
    "resolution": "720p",
    "aspectRatio": "auto",
    "audio": true
  }
}
