{
  "id": "seedance-1.5",
  "name": "Seedance 1.5 Pro",
  "description": "ByteDance's cinematic model with audio — 4–12s via kie.ai",
  "transport": "kie-video",
  "enabled": false,
  "apiKeyProvider": "kie",
  "models": {
    "textToVideo": "bytedance/seedance-1.5-pro",
    "imageToVideo": "bytedance/seedance-1.5-pro"
  },
  "paramMapping": {
    "duration": "duration",
    "aspectRatio": "aspect_ratio",
    "resolution": "resolution",
    "audio": "generate_audio",
