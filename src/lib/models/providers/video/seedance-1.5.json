    "resolutions": ["480p", "720p", "1080p"],
    "aspectRatios": ["1:1", "4:3", "3:4", "16:9", "9:16", "21:9"],
    "hasAudio": true
  },
  "defaults": {
    "duration": "8",
    "resolution": "720p",
    "aspectRatio": "16:9",
    "audio": false
  }
}
