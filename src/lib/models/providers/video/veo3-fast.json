{
  "id": "veo3-fast",
  "name": "Veo 3.1 Fast",
  "description": "Google's fast video generation model with audio ($0.15/sec)",
  "transport": "google-video",
  "transportOptions": {
    "initialPollInterval": 3000,
    "maxPollInterval": 8000
  },
  "enabled": true,
  "apiKeyProvider": "gemini",
  "models": {
    "textToVideo": "veo-3.1-fast-generate-preview",
    "imageToVideo": "veo-3.1-fast-generate-preview"
  },
  "capabilities": {
    "durations": ["8"],
    "hasAudio": true
  },
  "defaults": {
    "duration": "8"
  }
}
